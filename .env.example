# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored.

# Minimax 用于「我的产品爆款」产品 URL → 关键词/行业解析。
# 申请：https://www.minimaxi.com
#
# 本项目走 Minimax 的 Anthropic 兼容协议 `POST /anthropic/v1/messages`。
# 请求/响应都是 Claude API 标准格式，未来想换到真 Anthropic Claude 代码可复用。
MINIMAX_API_KEY=
# Group ID — Anthropic 兼容端点不需要，留空即可（保留变量是为了未来切回 chatcompletion_v2 时可用）
MINIMAX_GROUP_ID=
# 模型名 — 按你 key 的 plan 决定可用模型。已知可用：
#   MiniMax-M2.7          ✅ 当前 default（推理模型，输出前先 reasoning，需要更高的 max_tokens）
#   MiniMax-M2            ✅ 老一代推理模型，更便宜
MINIMAX_MODEL=MiniMax-M2.7
# Base URL — Anthropic 兼容协议挂在 minimaxi.com 域名下
MINIMAX_API_BASE=https://api.minimaxi.com

# ────────────────────────────────────────────────────────────────
# TikTok Creative Center 爬虫代理
#
# 本地 / 国内 IP 直连 TikTok ads.tiktok.com 大概率被反爬挡（captcha / 403 / 空数据）。
# 生产环境必走 IPRoyal 之类的住宅代理，并部署到海外服务器（阿里云硅谷 ECS）。
#
# 格式：scheme://user:pass@host:port
# IPRoyal 住宅代理示例（按你 dashboard 实际值填）：
#   TIKTOK_PROXY_URL=http://user_xxx:pass_yyy@geo.iproyal.com:12321
# 留空 = 不走代理，等同于本机直连（本机 smoke test 用，预期会撞 anti_bot）
TIKTOK_PROXY_URL=
