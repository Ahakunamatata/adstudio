# ========================================
# Studio Pipeline · 环境变量
# ========================================
# 复制为 .env 后填入真实值。.env 已在 .gitignore 里。

# ----------------------------------------
# Provider 选择
# ----------------------------------------
# 可选：fal | ark
# - fal：fal.ai 官方 SDK，海外 USD 计费，个人账号可注册（默认推荐）
# - ark：火山方舟（Volcengine Ark），需要企业认证
VIDEO_PROVIDER=fal

# ----------------------------------------
# fal.ai（默认 provider）
# ----------------------------------------
# 1. 注册：https://fal.ai
# 2. 拿 key：https://fal.ai/dashboard/keys
# 3. key 长这样：fal_xxxxxxxxxx
FAL_KEY=

# Seedance 2.0 image-to-video endpoint（默认值，不需要改）
FAL_ENDPOINT=bytedance/seedance-2.0/image-to-video

# ----------------------------------------
# 火山方舟（备用 provider）
# ----------------------------------------
# 控制台：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=
ARK_MODEL_ID=doubao-seedance-2-0-260128
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ----------------------------------------
# 运行参数
# ----------------------------------------
# 默认 N 条候选并行跑（每个变体生成几条供后续挑选）
DEFAULT_N_CANDIDATES=4

# 轮询任务状态间隔（秒）
POLL_INTERVAL_SEC=10

# 单任务最长等待（秒）
TASK_TIMEOUT_SEC=600
